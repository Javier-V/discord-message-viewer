# Discord Bot Token
# Get this from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Server Port
PORT=3000

# Discord channel to read
DISCORD_CHANNEL_ID=123456789012345678

# Optional: restrict to this guild/server
DISCORD_GUILD_ID=123456789012345678

# Optional: how many historical messages to load on startup/refresh
MAX_HISTORY_MESSAGES=1000

# Dashboard text channels, separated by commas
DASHBOARD_TEXT_CHANNEL_IDS=123456789012345678,234567890123456789

# Dashboard voice channels, separated by commas
DASHBOARD_VOICE_CHANNEL_IDS=345678901234567890,456789012345678901

# Optional: historical messages per dashboard text channel
DASHBOARD_MAX_HISTORY_MESSAGES_PER_CHANNEL=1000
